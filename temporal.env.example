# Настройки подключения к Temporal Server / Cloud
TEMPORAL_HOST_PORT=127.0.0.1:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=default-task-queue

# Настройки TLS подключения (опционально, например, для Temporal Cloud)
# TEMPORAL_CERT_PATH=/path/to/client.pem
# TEMPORAL_KEY_PATH=/path/to/client.key

# Настройки подключения к PostgreSQL (для системной активности CDC-делегирования)
TEMPORAL_DB_HOST=127.0.0.1
TEMPORAL_DB_PORT=5432
TEMPORAL_DB_USER=temporal
TEMPORAL_DB_PASSWORD=temporal_password
TEMPORAL_DB_NAME=temporal

# Настройки подключения к Sequin CDC (для высокопроизводительного CDC воркера)
SEQUIN_URL=http://127.0.0.1:7386
SEQUIN_CONSUMER=temporal_tasks
SEQUIN_API_TOKEN=sequin_loadtest_secret_token_12345

# Настройки шифрования полезной нагрузки (Zero-Trust)
TEMPORAL_ENCRYPTION_KEY=my_secure_dev_passphrase_1234567
TEMPORAL_CODEC_SERVER_PORT=8082
